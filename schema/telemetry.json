{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fenrir Unified Telemetry Schema",
  "type": "object",
  "required": [
    "eventId",
    "deviceId",
    "timestamp",
    "eventType",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "description": "Unique identifier for the event"
    },
    "deviceId": {
      "type": "string",
      "description": "Identifier for the device generating the event"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the event occurred"
    },
    "eventType": {
      "type": "string",
      "enum": [
        "ProcessStart",
        "NetworkConnect",
        "FileWrite"
      ],
      "description": "The normalized type of the event"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific data",
      "oneOf": [
        {
          "properties": {
            "eventType": { "const": "ProcessStart" }
          },
          "required": ["processName", "pid", "commandLine"]
        },
        {
          "properties": {
            "eventType": { "const": "NetworkConnect" }
          },
          "required": ["processName", "pid", "destinationIp", "destinationPort", "protocol"]
        },
        {
          "properties": {
            "eventType": { "const": "FileWrite" }
          },
          "required": ["processName", "pid", "filePath"]
        }
      ]
    }
  }
}
