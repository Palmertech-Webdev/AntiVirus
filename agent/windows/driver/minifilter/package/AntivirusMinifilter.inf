[Version]
Signature="$WINDOWS NT$"
Class=ActivityMonitor
ClassGuid={b86dff51-a31e-4bac-b3cf-e8cfe75c9fc2}
Provider=%ProviderName%
DriverVer=04/08/2026,0.1.0.0
CatalogFile=AntivirusMinifilter.cat

[DestinationDirs]
DefaultDestDir = 12

[DefaultInstall]
CopyFiles = DriverCopyFiles

[DefaultInstall.Services]
AddService = %ServiceName%,,ServiceInstall

[DriverCopyFiles]
AntivirusMinifilter.sys

[ServiceInstall]
DisplayName    = %ServiceDisplayName%
Description    = %ServiceDescription%
ServiceType    = 2
StartType      = 0
ErrorControl   = 1
ServiceBinary  = %12%\AntivirusMinifilter.sys
LoadOrderGroup = "FSFilter Activity Monitor"
Dependencies   = FltMgr

[SourceDisksNames]
1 = %DiskName%,,,

[SourceDisksFiles]
AntivirusMinifilter.sys = 1

[Strings]
ProviderName = "AntiVirus"
ServiceName = "AntivirusMinifilter"
ServiceDisplayName = "AntiVirus Real-Time Protection Minifilter"
ServiceDescription = "Intercepts file activity and asks the user-mode broker for real-time allow or block decisions."
DiskName = "AntiVirus Driver Installation Media"
